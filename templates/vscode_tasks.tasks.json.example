{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev-start (cursor_rules submodule)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\dev-start-cursor-rules.ps1"
      ],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "dev-start (submodule init only / SkipRemote)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\dev-start-cursor-rules.ps1",
        "-SkipRemote"
      ],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "check: markdown toc (project)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\check-markdown-toc.ps1",
        "-RootPath",
        "${workspaceFolder}"
      ],
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "fix: markdown toc (project)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\check-markdown-toc.ps1",
        "-RootPath",
        "${workspaceFolder}",
        "-Fix"
      ],
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "check: cursor_rules sanity",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\check-cursor-rules-sanity.ps1",
        "-RootPath",
        "${workspaceFolder}\\\\cursor_rules"
      ],
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "run: checklist A (all rules)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\run-checklist-a.ps1",
        "-ProjectRoot",
        "${workspaceFolder}"
      ],
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "run: checklist A (manual review done)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\run-checklist-a.ps1",
        "-ProjectRoot",
        "${workspaceFolder}",
        "-ManualReviewOk"
      ],
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "sync: checklist A spec (mdc -> spec)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\sync-checklist-a-spec.ps1",
        "-RootPath",
        "${workspaceFolder}\\\\cursor_rules"
      ],
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
