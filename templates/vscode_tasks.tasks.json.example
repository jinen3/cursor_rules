{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev-start (cursor_rules submodule)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\dev-start-cursor-rules.ps1"
      ],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "dev-start (submodule init only / SkipRemote)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\dev-start-cursor-rules.ps1",
        "-SkipRemote"
      ],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "check: markdown toc (project)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\\\cursor_rules\\\\scripts\\\\check-markdown-toc.ps1",
        "-RootPath",
        "${workspaceFolder}"
      ],
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}

